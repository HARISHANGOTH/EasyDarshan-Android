<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clHomeRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/screen_margin_horizontal"
            android:paddingEnd="@dimen/screen_margin_horizontal"
            android:paddingTop="@dimen/spacing_16"
            android:paddingBottom="@dimen/bottom_content_padding">

            <!-- ========================= -->
            <!-- Toolbar -->
            <!-- ========================= -->

            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="@dimen/toolbar_icon_size"
                android:layout_height="@dimen/toolbar_icon_size"
                android:src="@drawable/ic_menu"
                android:contentDescription="@string/cd_menu"
                app:tint="@color/foreground"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textStyle="bold"
                android:textSize="@dimen/text_2xl"
                android:textColor="@color/primary"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintStart_toEndOf="@id/ivMenu"
                app:layout_constraintTop_toTopOf="@id/ivMenu"
                app:layout_constraintBottom_toBottomOf="@id/ivMenu"
                android:layout_marginStart="@dimen/spacing_12"/>

            <FrameLayout
                android:id="@+id/flNotification"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivMenu"
                app:layout_constraintBottom_toBottomOf="@id/ivMenu">

                <ImageView
                    android:id="@+id/ivNotification"
                    android:layout_width="@dimen/toolbar_icon_size"
                    android:layout_height="@dimen/toolbar_icon_size"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_notification"
                    app:tint="@color/foreground"
                    android:contentDescription="@string/cd_notification"/>

                <View
                    android:id="@+id/viewBadge"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_notification_badge"/>

            </FrameLayout>

            <!-- ========================= -->
            <!-- Greeting -->
            <!-- ========================= -->

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/namaste"
                android:textSize="@dimen/text_lg"
                android:textColor="@color/foreground_secondary"
                android:layout_marginTop="@dimen/spacing_32"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivMenu"/>

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harish 👋"
                android:textSize="@dimen/text_heading"
                android:textStyle="bold"
                android:textColor="@color/foreground"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="@dimen/spacing_4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvGreeting"/>

            <!-- ========================= -->
            <!-- Search Bar -->
            <!-- ========================= -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSearch"
                android:layout_width="0dp"
                android:layout_height="@dimen/search_bar_height"
                android:layout_marginTop="@dimen/spacing_24"
                app:cardCornerRadius="@dimen/radius_large"
                app:cardElevation="@dimen/card_elevation"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/surface"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvUserName">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="@dimen/spacing_16"
                    android:paddingEnd="@dimen/spacing_16">

                    <ImageView
                        android:id="@+id/ivSearch"
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@drawable/ic_search"
                        app:tint="@color/foreground_muted"
                        android:contentDescription="@string/cd_search"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <EditText
                        android:id="@+id/etSearchTemple"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:background="@null"
                        android:hint="@string/search_temple"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:textColor="@color/foreground"
                        android:textColorHint="@color/foreground_muted"
                        android:textSize="@dimen/text_md"
                        android:importantForAutofill="no"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivSearch"
                        app:layout_constraintTop_toTopOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- =========================================== -->
            <!-- Nearby Live Queue Section -->
            <!-- =========================================== -->

            <TextView
                android:id="@+id/tvNearbyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_32"
                android:text="@string/nearby_live_queues"
                android:textColor="@color/foreground"
                android:textSize="@dimen/text_section_title"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardSearch"/>

            <TextView
                android:id="@+id/tvViewAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/view_all"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_base"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                app:layout_constraintBottom_toBottomOf="@id/tvNearbyTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvNearbyTitle"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNearbyTemples"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:overScrollMode="never"
                tools:itemCount="5"
                tools:listitem="@layout/item_nearby_temple"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/tvNearbyTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- ========================================= -->
            <!-- Plan Your Visit Banner -->
            <!-- ========================================= -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPlanVisit"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/spacing_32"
                app:cardBackgroundColor="@color/banner_background"
                app:cardCornerRadius="@dimen/radius_xlarge"
                app:cardElevation="@dimen/card_elevation"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/rvNearbyTemples"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Heading -->
                    <TextView
                        android:id="@+id/tvPlanTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_20"
                        android:layout_marginTop="@dimen/spacing_20"
                        android:layout_marginEnd="150dp"
                        android:text="@string/banner_title"
                        android:textColor="@color/foreground"
                        android:textSize="@dimen/text_2xl"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <!-- Subtitle -->
                    <TextView
                        android:id="@+id/tvPlanSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8"
                        android:text="@string/banner_subtitle"
                        android:textColor="@color/foreground_secondary"
                        android:textSize="@dimen/text_base"
                        android:lineSpacingExtra="2dp"
                        app:layout_constraintTop_toBottomOf="@id/tvPlanTitle"
                        app:layout_constraintStart_toStartOf="@id/tvPlanTitle"
                        app:layout_constraintEnd_toStartOf="@id/ivTempleIllustration"/>

                    <!-- CTA Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBookDarshan"
                        style="@style/Widget.EasyDarshan.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/btn_height_sm"
                        android:layout_marginTop="@dimen/spacing_16"
                        android:text="@string/book_darshan"
                        android:textAllCaps="false"
                        android:textSize="@dimen/text_md"
                        android:contentDescription="@string/cd_book_darshan_now"
                        app:layout_constraintTop_toBottomOf="@id/tvPlanSubtitle"
                        app:layout_constraintStart_toStartOf="@id/tvPlanSubtitle"/>

                    <!-- Illustration -->
                    <ImageView
                        android:id="@+id/ivTempleIllustration"
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        android:layout_marginEnd="@dimen/spacing_8"
                        android:src="@drawable/ic_temple_banner"
                        android:scaleType="fitCenter"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ========================================= -->
            <!-- Notification Permission Card -->
            <!-- ========================================= -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNotification"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_20"
                android:layout_marginTop="@dimen/spacing_16"
                android:layout_marginEnd="@dimen/spacing_20"
                app:cardCornerRadius="@dimen/radius_large"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardPlanVisit">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F0F6FF"
                    android:padding="@dimen/spacing_20">

                    <TextView
                        android:id="@+id/tvNotifTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/notif_card_title"
                        android:textColor="@color/foreground"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/ivBellIllustration"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvNotifSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_4"
                        android:text="@string/notif_card_subtitle"
                        android:textColor="@color/foreground_secondary"
                        android:textSize="@dimen/text_sm"
                        app:layout_constraintEnd_toStartOf="@id/btnEnableNotifications"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvNotifTitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnableNotifications"
                        style="@style/Widget.EasyDarshan.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/btn_height_sm"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:text="@string/notif_card_enable"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvNotifSubtitle" />

                    <ImageView
                        android:id="@+id/ivBellIllustration"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_notification"
                        app:tint="#BFDBFE"
                        android:contentDescription="@string/cd_bell_illustration"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ========================================= -->
            <!-- Bottom Space -->
            <!-- ========================================= -->

            <Space
                android:id="@+id/spaceBottom"
                android:layout_width="0dp"
                android:layout_height="90dp"
                app:layout_constraintTop_toBottomOf="@id/cardNotification"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
