<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray"
    tools:context=".ui.prebooking.PreBookingFlowActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_rounded"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/backButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/white"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/back" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/flowTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Book Darshan"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/templeName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tirumala Venkateswara Temple"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:alpha="0.8"
                        android:layout_marginTop="2dp"
                        tools:text="Tirumala Venkateswara Temple" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Main Content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <FrameLayout
                android:id="@+id/stepContentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <!-- Step 1: Date Selection -->
                <LinearLayout
                    android:id="@+id/step1Content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Date"
                        android:textColor="@color/foreground"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/datesRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:listitem="@layout/item_date" />
                </LinearLayout>

                <!-- Step 2: Slot Selection -->
                <LinearLayout
                    android:id="@+id/step2Content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Time Slot"
                        android:textColor="@color/foreground"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/slotsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:listitem="@layout/item_time_slot" />
                </LinearLayout>

                <!-- Step 3: Devotee Details -->
                <LinearLayout
                    android:id="@+id/step3Content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Devotee Details"
                        android:textColor="@color/foreground"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <!-- Adults Counter -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Adults"
                                        android:textColor="@color/foreground"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Age 12+"
                                        android:textColor="@color/foreground_secondary"
                                        android:textSize="12sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_circle_primary_light"
                                    android:padding="4dp">
                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/decrementAdults"
                                        style="@style/Widget.Material3.Button.IconButton.Filled"
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        android:text="-"
                                        android:textSize="18sp"
                                        app:cornerRadius="18dp"
                                        app:backgroundTint="@color/primary"
                                        android:textColor="@color/white"
                                        android:padding="0dp" />
                                    <TextView
                                        android:id="@+id/adultCount"
                                        android:layout_width="40dp"
                                        android:layout_height="wrap_content"
                                        android:text="1"
                                        android:textColor="@color/foreground"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:gravity="center" />
                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/incrementAdults"
                                        style="@style/Widget.Material3.Button.IconButton.Filled"
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        android:text="+"
                                        android:textSize="18sp"
                                        app:cornerRadius="18dp"
                                        app:backgroundTint="@color/primary"
                                        android:textColor="@color/white"
                                        android:padding="0dp" />
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/border"
                                android:layout_marginTop="16dp"
                                android:layout_marginBottom="16dp" />

                            <!-- Children Counter -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Children"
                                        android:textColor="@color/foreground"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Age 5-12"
                                        android:textColor="@color/foreground_secondary"
                                        android:textSize="12sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_circle_primary_light"
                                    android:padding="4dp">
                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/decrementChildren"
                                        style="@style/Widget.Material3.Button.IconButton.Filled"
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        android:text="-"
                                        android:textSize="18sp"
                                        app:cornerRadius="18dp"
                                        app:backgroundTint="@color/primary"
                                        android:textColor="@color/white"
                                        android:padding="0dp" />
                                    <TextView
                                        android:id="@+id/childrenCount"
                                        android:layout_width="40dp"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textColor="@color/foreground"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:gravity="center" />
                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/incrementChildren"
                                        style="@style/Widget.Material3.Button.IconButton.Filled"
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        android:text="+"
                                        android:textSize="18sp"
                                        app:cornerRadius="18dp"
                                        app:backgroundTint="@color/primary"
                                        android:textColor="@color/white"
                                        android:padding="0dp" />
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/border"
                                android:layout_marginTop="16dp"
                                android:layout_marginBottom="16dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Devotee Names"
                                android:textColor="@color/foreground"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp"/>

                            <!-- Names Container -->
                            <LinearLayout
                                android:id="@+id/namesContainer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginBottom="8dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Step 4: Payment Summary -->
                <LinearLayout
                    android:id="@+id/step4Content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Booking Summary"
                        android:textColor="@color/foreground"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:id="@+id/summaryTempleName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sri Venkateswara Temple"
                                android:textColor="@color/foreground"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="12dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_calendar"
                                    app:tint="@color/foreground_secondary"
                                    android:layout_gravity="center_vertical"
                                    android:layout_marginEnd="8dp"/>
                                <TextView
                                    android:id="@+id/summaryDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Wednesday, 20 March 2024"
                                    android:textColor="@color/foreground_secondary"
                                    android:textSize="14sp"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_clock"
                                    app:tint="@color/foreground_secondary"
                                    android:layout_gravity="center_vertical"
                                    android:layout_marginEnd="8dp"/>
                                <TextView
                                    android:id="@+id/summaryTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="06:00 AM - 07:00 AM"
                                    android:textColor="@color/foreground_secondary"
                                    android:textSize="14sp"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="16dp">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_launcher_foreground"
                                    app:tint="@color/foreground_secondary"
                                    android:layout_gravity="center_vertical"
                                    android:layout_marginEnd="8dp"/>
                                <TextView
                                    android:id="@+id/summaryDevotees"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2 Devotees"
                                    android:textColor="@color/foreground_secondary"
                                    android:textSize="14sp"/>
                            </LinearLayout>

                            <!-- Devotee Names Summary -->
                            <TextView
                                android:id="@+id/summaryDevoteeNames"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/foreground_secondary"
                                android:textSize="14sp"
                                android:layout_marginBottom="8dp"
                                android:visibility="gone"
                                tools:text="Names: Mahesh, Suresh"
                                tools:visibility="visible"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_shield"
                                    app:tint="@color/foreground_secondary"
                                    android:layout_gravity="center_vertical"
                                    android:layout_marginEnd="8dp"/>
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Booking Reference"
                                    android:textColor="@color/foreground_secondary"
                                    android:textSize="14sp"/>
                                <TextView
                                    android:id="@+id/summaryReferenceId"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ED20240320XXXX"
                                    android:textColor="@color/foreground"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/border_light"
                                android:layout_marginBottom="16dp"/>

                            <!-- Price Breakdown -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:id="@+id/darshanFeeLabel"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Darshan Fee"
                                    android:textColor="@color/foreground_secondary"
                                    android:textSize="14sp"/>
                                <TextView
                                    android:id="@+id/darshanFee"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹600"
                                    android:textColor="@color/foreground"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="12dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Platform Fee"
                                    android:textColor="@color/foreground_secondary"
                                    android:textSize="14sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹20"
                                    android:textColor="@color/foreground"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingTop="16dp"
                                android:background="@drawable/bg_golden_divider"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Total Payable"
                                    android:textColor="@color/foreground"
                                    android:textSize="18sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:id="@+id/totalAmount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹620"
                                    android:textColor="@color/primary"
                                    android:textSize="22sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Cancellation Policy: Non-refundable after confirmation."
                                android:textColor="@color/error"
                                android:textSize="12sp"
                                android:layout_marginTop="16dp"
                                android:gravity="center_horizontal"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:layout_marginTop="12dp"
                                android:alpha="0.7">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔒 Secure payment powered by Razorpay"
                                    android:textColor="@color/foreground_secondary"
                                    android:textSize="12sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Step 5: Verifying Payment Screen -->
                <LinearLayout
                    android:id="@+id/verifyingContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:indeterminateTint="@color/primary"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verifying Payment..."
                        android:textColor="@color/foreground"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Please do not press back or close the app"
                        android:textColor="@color/foreground_secondary"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Step 6: Payment Successful Screen -->
                <LinearLayout
                    android:id="@+id/successContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/success_light"
                        android:layout_marginBottom="24dp">
                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_launcher_foreground"
                            app:tint="@color/success" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Successful"
                        android:textColor="@color/success"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Booking Summary Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        android:layout_marginBottom="32dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:id="@+id/successTempleName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Tirumala Venkateswara Temple"
                                android:textColor="@color/foreground"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:layout_marginBottom="16dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Booking ID"
                                    android:textColor="@color/foreground_secondary" />
                                <TextView
                                    android:id="@+id/successBookingId"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="BK17722956"
                                    android:textColor="@color/foreground"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Persons"
                                    android:textColor="@color/foreground_secondary" />
                                <TextView
                                    android:id="@+id/successPersons"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2"
                                    android:textColor="@color/foreground"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Queue Token"
                                    android:textColor="@color/foreground_secondary" />
                                <TextView
                                    android:id="@+id/successToken"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="#452"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Est. Entry Time"
                                    android:textColor="@color/foreground_secondary" />
                                <TextView
                                    android:id="@+id/successEntryTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="11:30 AM"
                                    android:textColor="@color/foreground"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/goToLiveQueueButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Go to Live Queue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:paddingVertical="16dp"
                        app:cornerRadius="16dp"
                        app:backgroundTint="@color/primary"
                        android:textColor="@color/white" />
                </LinearLayout>

                <!-- Payment Failed Screen -->
                <LinearLayout
                    android:id="@+id/failedContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/error_light"
                        android:layout_marginBottom="24dp">
                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_launcher_foreground"
                            app:tint="@color/error" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Failed"
                        android:textColor="@color/error"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Failed – Please try again"
                        android:textColor="@color/foreground_secondary"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginBottom="48dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/retryPaymentButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Retry Payment"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:paddingVertical="16dp"
                        android:layout_marginBottom="12dp"
                        app:cornerRadius="16dp"
                        app:backgroundTint="@color/primary"
                        android:textColor="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/cancelBookingButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cancel Booking"
                        android:textColor="@color/foreground_secondary" />
                </LinearLayout>

            </FrameLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Sticky Bottom Button Area -->
        <FrameLayout
            android:id="@+id/bottomActionArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:background="@color/background_gray">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/continueToPaymentButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Continue to Payment"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:enabled="true"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/confirmPayButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Confirm &amp; Pay"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:visibility="visible" />
        </FrameLayout>

    </LinearLayout>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_white"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
