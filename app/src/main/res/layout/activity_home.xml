<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".ui.home.HomeActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/bottom_content_padding">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ===== HERO HEADER IMAGE ===== -->
            <ImageView
                android:id="@+id/ivHeaderHero"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:src="@drawable/img_plan_visit"
                android:scaleType="centerCrop"
                android:alpha="0.2"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_header_fade"
                app:layout_constraintBottom_toBottomOf="@id/ivHeaderHero" />

            <!-- ===== TOOLBAR ===== -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/toolbar"
                android:layout_width="0dp"
                android:layout_height="@dimen/toolbar_height"
                android:paddingStart="@dimen/screen_margin_horizontal"
                android:paddingEnd="@dimen/screen_margin_horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="@dimen/toolbar_icon_size"
                    android:layout_height="@dimen/toolbar_icon_size"
                    android:src="@drawable/ic_menu"
                    android:contentDescription="@string/cd_menu"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/foreground"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <LinearLayout
                    android:id="@+id/logoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    app:layout_constraintStart_toEndOf="@id/btnMenu"
                    app:layout_constraintEnd_toStartOf="@id/btnNotification"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:id="@+id/ivLogoIcon"
                        android:layout_width="@dimen/logo_icon_size"
                        android:layout_height="@dimen/logo_icon_size"
                        android:src="@drawable/ic_logo_temple"
                        android:contentDescription="@string/cd_logo" />

                    <TextView
                        android:id="@+id/tvLogoEasy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/app_logo_easy"
                        android:textAppearance="@style/TextAppearance.EasyDarshan.AppName" />

                    <TextView
                        android:id="@+id/tvLogoDarshan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_logo_darshan"
                        android:textAppearance="@style/TextAppearance.EasyDarshan.AppName" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnNotification"
                    android:layout_width="@dimen/toolbar_icon_size"
                    android:layout_height="@dimen/toolbar_icon_size"
                    android:src="@drawable/ic_notification"
                    android:contentDescription="@string/cd_notification"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/foreground"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ===== GREETING SECTION ===== -->
            <TextView
                android:id="@+id/tvNamaste"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/namaste"
                android:textAppearance="@style/TextAppearance.EasyDarshan.Greeting"
                android:layout_marginStart="@dimen/screen_margin_horizontal"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/toolbar"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.EasyDarshan.UserName"
                android:layout_marginStart="@dimen/screen_margin_horizontal"
                android:layout_marginEnd="@dimen/screen_margin_horizontal"
                android:layout_marginTop="4dp"
                tools:text="Mahesh Kumar 🙏"
                app:layout_constraintTop_toBottomOf="@id/tvNamaste"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ===== SEARCH BAR (Google Pay Style) ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchBar"
                android:layout_width="0dp"
                android:layout_height="@dimen/search_bar_height"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                app:layout_constraintTop_toBottomOf="@id/tvUserName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/icSearch"
                        android:layout_width="@dimen/search_icon_size"
                        android:layout_height="@dimen/search_icon_size"
                        android:src="@drawable/ic_search"
                        android:layout_marginStart="16dp"
                        app:tint="@color/foreground_muted"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/searchInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:hint="@string/search_temple"
                        android:textSize="15sp"
                        android:textColor="@color/foreground"
                        android:textColorHint="@color/text_hint"
                        android:background="@android:color/transparent"
                        android:paddingStart="12dp"
                        android:paddingEnd="16dp"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:singleLine="true"
                        android:fontFamily="sans-serif-medium"
                        android:contentDescription="@string/cd_search"
                        app:layout_constraintStart_toEndOf="@id/icSearch"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== NEARBY TEMPLES SECTION ===== -->
            <TextView
                android:id="@+id/tvNearbyTemples"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/nearby_temples"
                android:textAppearance="@style/TextAppearance.EasyDarshan.SectionTitle"
                android:layout_marginStart="@dimen/screen_margin_horizontal"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/searchBar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnViewAll" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewAll"
                style="@style/Widget.EasyDarshan.Button.TextLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/view_all"
                android:contentDescription="@string/cd_view_all_temples"
                android:layout_marginEnd="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvNearbyTemples"
                app:layout_constraintBottom_toBottomOf="@id/tvNearbyTemples" />

            <!-- ===== NEARBY TEMPLES CONTAINER ===== -->
            <FrameLayout
                android:id="@+id/templesContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvNearbyTemples"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- ===== SHIMMER LOADING ===== -->
                <include
                    android:id="@+id/shimmerLayout"
                    layout="@layout/layout_shimmer_temples"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <!-- ===== HORIZONTAL TEMPLE RECYCLERVIEW ===== -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNearbyTemples"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_temple_card_horizontal"
                    tools:itemCount="3" />

                <!-- ===== EMPTY STATE ===== -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/emptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="32dp"
                    android:paddingBottom="32dp"
                    android:layout_marginHorizontal="@dimen/screen_margin_horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/ivEmptyIcon"
                        android:layout_width="@dimen/icon_size_xxl"
                        android:layout_height="@dimen/icon_size_xxl"
                        android:src="@drawable/ic_temple_placeholder"
                        android:alpha="0.4"
                        app:tint="@color/foreground_muted"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvEmptyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_nearby_temples"
                        android:textColor="@color/foreground"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@id/ivEmptyIcon"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvEmptySubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_nearby_temples_msg"
                        android:textColor="@color/foreground_secondary"
                        android:textSize="@dimen/text_base"
                        android:gravity="center"
                        android:layout_marginTop="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tvEmptyTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ===== ERROR STATE ===== -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/errorState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:layout_marginHorizontal="@dimen/screen_margin_horizontal"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvErrorTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_internet"
                        android:textColor="@color/foreground"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvErrorSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_internet_msg"
                        android:textColor="@color/foreground_secondary"
                        android:textSize="@dimen/text_base"
                        android:gravity="center"
                        android:layout_marginTop="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tvErrorTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRetry"
                        style="@style/Widget.EasyDarshan.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/retry"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvErrorSubtitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </FrameLayout>

            <!-- ===== BANNER CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bannerCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/screen_margin_horizontal"
                android:layout_marginEnd="@dimen/screen_margin_horizontal"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/banner_background"
                app:layout_constraintTop_toBottomOf="@id/templesContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvBannerTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/banner_title"
                        android:textAppearance="@style/TextAppearance.EasyDarshan.SectionTitle"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivBannerIllustration"
                        app:layout_constraintWidth_percent="0.6" />

                    <TextView
                        android:id="@+id/tvBannerSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/banner_subtitle"
                        android:textAppearance="@style/TextAppearance.EasyDarshan.Caption"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tvBannerTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivBannerIllustration"
                        app:layout_constraintWidth_percent="0.6" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBookDarshanNow"
                        style="@style/Widget.EasyDarshan.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/banner_cta"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tvBannerSubtitle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <ImageView
                        android:id="@+id/ivBannerIllustration"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:src="@drawable/img_plan_visit"
                        android:scaleType="fitCenter"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== NOTIFICATION CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/notificationCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/screen_margin_horizontal"
                android:layout_marginEnd="@dimen/screen_margin_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="100dp"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/notif_card_bg"
                app:layout_constraintTop_toBottomOf="@id/bannerCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvNotifTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/notif_card_title"
                        android:textAppearance="@style/TextAppearance.EasyDarshan.SectionTitle"
                        app:layout_constraintEnd_toStartOf="@id/ivBellIllustration"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvNotifSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/notif_card_subtitle"
                        android:textAppearance="@style/TextAppearance.EasyDarshan.Caption"
                        android:layout_marginTop="4dp"
                        app:layout_constraintEnd_toStartOf="@id/ivBellIllustration"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvNotifTitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnableNotifications"
                        style="@style/Widget.EasyDarshan.Button.Primary"
                        android:layout_width="@dimen/btn_enable_width"
                        android:layout_height="@dimen/btn_enable_height"
                        android:text="@string/notif_card_enable"
                        android:layout_marginTop="12dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvNotifSubtitle"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:id="@+id/btnDismissNotif"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/foreground_secondary"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <ImageView
                        android:id="@+id/ivBellIllustration"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/img_notif_bell"
                        android:scaleType="fitCenter"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== FLOATING BOTTOM NAVIGATION ===== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:layout_behavior="com.google.android.material.behavior.HideBottomViewOnScrollBehavior">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@color/white"
            app:itemIconSize="24dp"
            app:itemIconTint="@color/bottom_nav_selector"
            app:itemTextColor="@color/bottom_nav_selector"
            app:itemTextAppearanceActive="@style/BottomNavText"
            app:itemTextAppearanceInactive="@style/BottomNavText"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_bottom_navigation" />

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
