<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Temple Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="@color/muted">

            <ImageView
                android:id="@+id/templeImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@drawable/ic_temple" />

            <!-- Queue Status Badge -->
            <TextView
                android:id="@+id/queueStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High Queue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/bg_queue_status_high"
                android:layout_gravity="top|end"
                android:layout_margin="12dp" />
        </FrameLayout>

        <!-- Temple Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/templeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sri Venkateswara Temple"
                android:textColor="@color/foreground"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                tools:text="Sri Venkateswara Temple" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/foreground_secondary"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/templeLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tirupati, Andhra Pradesh"
                    android:textColor="@color/foreground_secondary"
                    android:textSize="14sp"
                    tools:text="Tirupati, Andhra Pradesh" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/foreground_secondary"
                    android:textSize="14sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/templeDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.3 km"
                    android:textColor="@color/foreground_secondary"
                    android:textSize="14sp"
                    tools:text="2.3 km" />
            </LinearLayout>

            <!-- Book Darshan Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/bookDarshanButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Book Darshan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/primary"
                android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

