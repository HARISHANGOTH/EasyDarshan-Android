<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border_light"
    app:cardBackgroundColor="@color/white"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Temple Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/muted">

            <ImageView
                android:id="@+id/templeImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@drawable/ic_temple" />

            <!-- Queue Status Badge -->
            <TextView
                android:id="@+id/queueStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High Queue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/bg_floating_nav"
                android:backgroundTint="@color/overlay_white"
                android:textColor="@color/error"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:elevation="4dp" />
        </FrameLayout>

        <!-- Temple Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/templeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sri Venkateswara Temple"
                android:textColor="@color/foreground"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"
                tools:text="Sri Venkateswara Temple" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/foreground_secondary"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/templeLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tirupati, Andhra Pradesh"
                    android:textColor="@color/foreground_secondary"
                    android:textSize="14sp"
                    tools:text="Tirupati, Andhra Pradesh" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/foreground_secondary"
                    android:textSize="14sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/templeDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.3 km"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="2.3 km" />
            </LinearLayout>

            <!-- Book Now Button - Improved UI -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/bookDarshanButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Book Darshan"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/primary"
                android:textColor="@color/white"
                app:elevation="4dp"
                app:icon="@drawable/ic_calendar"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/white" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>