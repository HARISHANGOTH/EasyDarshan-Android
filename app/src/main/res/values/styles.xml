<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Typography -->
    <style name="TextAppearance.EasyDarshan.AppName" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_app_name</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.EasyDarshan.Greeting" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/foreground</item>
        <item name="android:textSize">@dimen/text_greeting</item>
    </style>

    <style name="TextAppearance.EasyDarshan.UserName" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/foreground</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_user_name</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.EasyDarshan.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/foreground</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_section</item>
    </style>

    <style name="TextAppearance.EasyDarshan.TempleName" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/foreground</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_temple_name</item>
    </style>

    <style name="TextAppearance.EasyDarshan.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_body</item>
        <item name="android:textSize">@dimen/text_base</item>
    </style>

    <style name="TextAppearance.EasyDarshan.Caption" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/foreground_secondary</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.EasyDarshan.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.EasyDarshan.Button.TextLink" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Navigation -->
    <style name="BottomNavText">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="ShapeAppearanceOverlay.EasyDarshan.CardImage" parent="">
        <item name="cornerSizeTopLeft">@dimen/radius_card</item>
        <item name="cornerSizeTopRight">@dimen/radius_card</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="Widget.EasyDarshan.SearchBar" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeColor">@color/border_light</item>
        <item name="strokeWidth">1dp</item>
    </style>

</resources>
